@* /Pages/Shared/_Layout.cshtml *@
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - KhumaloCraftEmporium_ST10265272</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/Styles.css" asp-append-version="true" />
    <link href="~/lib/font-awesome/css/all.min.css" rel="stylesheet" />
</head>

<body class="kc-body @(ViewData["BodyClass"] ?? "")">
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark kc-nav fixed-top">
            <div class="container">
                <a class="navbar-brand kc-brand" asp-area="" asp-page="/Index">KhumaloCraft</a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse"
                        aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1 kc-navlinks">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-page="/Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-page="/MyWork2">My Work</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-page="/AboutUs">About Us</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-page="/ContactUs">Contact Us</a>
                        </li>
                    </ul>

                    <ul class="navbar-nav align-items-center gap-2">
                        <li class="nav-item">
                            <a class="btn kc-btn kc-btn-outline" asp-area="" asp-page="/Login/LoginPage">Admin Login</a>
                        </li>
                   
                        <li class="nav-item">
                            <a class="kc-cart position-relative" href="/AddCart/Cart" aria-label="Cart">
                                <i class="fas fa-shopping-cart"></i>
                                <span class="kc-cart-badge">2</span>
                            </a>
                        </li>
                    </ul>

                </div>
            </div>
        </nav>
    </header>

    <main role="main" class="kc-main">
        @RenderBody()
    </main>

    <footer class="border-top footer text-muted kc-footer">
        <div class="container">
            &copy; 2024 J.Khumalo/KM Katapa Solutions, POE Production Committee -
            <a asp-area="" asp-page="/Privacy">Privacy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
