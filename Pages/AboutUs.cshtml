@page
@model KhumaloCraftEmporium_ST10265272.Pages.AboutUsModel
@{
    ViewData["Title"] = "About Us";
}

<section class="about-hero">
    <div class="about-wrap">

        <div class="about-card">

            <header class="about-header">
                <h1 class="about-title">About Us</h1>
                <p class="about-lead">
                    Welcome to KhumaloCraft Emporium, your premier destination for handcrafted treasures from artisans around the globe.
                    Founded by visionary entrepreneur James Khumalo, our platform aims to bridge the gap between talented artisans and
                    discerning customers seeking unique, authentic products with a story.
                </p>
            </header>

            <div class="about-grid">

               
                <div class="about-content">

                    <div class="about-section">
                        <h2 class="about-h2">What We Offer</h2>
                        <p>
                            At KhumaloCraft Emporium, you'll discover a treasure trove of handcrafted goods, each meticulously crafted with love
                            and attention to detail. Whether you're searching for a statement piece to adorn your home or a meaningful gift for a
                            loved one, our curated collection has something for every taste and occasion.
                        </p>

                        <p class="about-muted">Browse through our categories to explore a world of artisanal excellence:</p>

                        <ul class="about-list">
                            <li><strong>Jewelry:</strong> Adorn yourself with stunning jewelry handcrafted by skilled artisans using traditional techniques and ethically sourced materials.</li>
                            <li><strong>Home Decor:</strong> Transform your living space with handwoven textiles, intricately carved sculptures, and vibrant ceramics.</li>
                            <li><strong>Fashion Accessories:</strong> Elevate your style with handwoven scarves, leather bags, and unique statement pieces that reflect your individuality.</li>
                            <li><strong>Gifts:</strong> Choose from a curated selection of handcrafted treasures that are sure to delight and inspire.</li>
                        </ul>
                    </div>

                    <div class="about-section">
                        <h2 class="about-h2">Join Us on Our Journey</h2>
                        <p>
                            Join us on our journey to celebrate the beauty of handmade craftsmanship and support talented artisans worldwide.
                            Whether you're a seasoned collector or a first-time shopper, we invite you to explore our collection and discover the
                            magic of KhumaloCraft Emporium.
                        </p>
                        <p>
                            Thank you for supporting independent artisans and for choosing to make a difference with every purchase.
                        </p>

                        <div class="about-callout">
                            <span class="about-badge">Our mission</span>
                            <p>Make handcrafted artistry easier to discover — and more sustainable for the makers behind it.</p>
                        </div>
                    </div>

                </div>

            
                <aside class="about-aside">
                    <figure class="about-figure">
                        <img class="about-img" src="~/img/black-businessman-with-beard-on-phone.jpg" alt="James Khumalo, CEO" />
                        <figcaption class="about-caption">
                            <div class="about-name">James Khumalo</div>
                            <div class="about-role">CEO</div>
                        </figcaption>
                    </figure>
                </aside>

            </div>
        </div>

    </div>
</section>
